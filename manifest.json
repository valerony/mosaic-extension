{
    "manifest_version": 3,
    "name": "Загрузчик статей на Mosaic",
    "version": "0.1",
    "description": "Загрузчик статей на Mosaic - это расширение для браузера, которое позволяет пользователям легко загружать статьи и сохранять их в своем аккаунте на платформе Mosaic. С помощью этого расширения пользователи могут быстро сохранять интересные статьи, которые они находят в интернете, и организовывать их для дальнейшего чтения и использования.",
    "permissions": [
        "storage",
        "downloads",
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_title": "Загрузчик статей на Mosaic",
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "dist/background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content_proxy.js"],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["injected_page.js"],
            "matches": ["<all_urls>"]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}